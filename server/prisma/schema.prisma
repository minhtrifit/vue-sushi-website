generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum SectionType {
  HOME
  ABOUT
  SPECIAL
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  fullName  String
  role      Role     @default(USER)
  isActive  Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Section {
  id        String      @id @default(uuid())
  mainTitle String
  subTitle  String
  content   String
  type      SectionType @unique
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

